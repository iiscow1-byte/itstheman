{
    "geode": "5.6.1",
    "gd": {
        "android": "2.2081",
        "win": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "version": "v1.7.13",
    "id": "gerg.integrated_levellists",
    "name": "Integrated Level lists",
    "developer": "gerg",
    "description": "level list integration",
    "resources": {
        "files": [
            "resources/*.frag",
            "resources/*.vert"
        ],
        "sprites": [
            "resources/*.png"
        ]
    },
    "settings": {
        "show-mscl": {
            "name": "Show MSCL",
            "description": "Whether to show the MSCL as a list option and in level rank badges.",
            "type": "bool",
            "default": false
        },
        "enable-rank": {
            "name": "Enable Level Ranking Text",
            "description": "Whether or not to display the demon ranking text.",
            "type": "bool",
            "default": true
        },
        "white-rank": {
            "name": "White Level Ranking Text",
            "description": "Whether or not to display the demon ranking text in white.",
            "type": "bool",
            "enable-if": "enable-rank",
            "default": false
        }
    },
    "dependencies": {
        "geode.node-ids": ">=v1.9.0"
    },
    "links": {
        "source": "https://github.com/iiscow1-byte/itstheman"
    },
    "tags": [
        "content",
        "enhancement",
        "interface",
        "online",
        "utility"
    ]
}
